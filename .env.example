# ── Required ───────────────────────────────────────────────────────────
# Bot token for Telegram API. Required for both polling and webhook modes.
TELEGRAM_BOT_TOKEN=

# ── Providers ──────────────────────────────────────────────────────────
# API key for OpenAI-compatible providers (the default config uses this
# for planner, architect, coder, tester, and reviewer agents).
OPENAI_API_KEY=

# If you configure additional providers in config.yaml, set their env vars
# here. Example:
# DEEPSEEK_API_KEY=
# KIMI_API_KEY=
# AZURE_OPENAI_API_KEY=

# ── Webhook (optional) ─────────────────────────────────────────────────
# Secret token for Telegram webhook verification. The bot refuses to
# start in webhook mode without this variable set.
# TELEGRAM_WEBHOOK_SECRET=

# ── Source control (optional) ──────────────────────────────────────────
# If you use GitLab integration, authenticate with:
# GITLAB_TOKEN=